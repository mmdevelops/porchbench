# porchbench configuration
# Copy this file to .env and uncomment the settings you want to change.
# CLI flags always take precedence over env vars.

# --- Evaluation backend ---
# Which backend to use for LLM-as-judge scoring.
# Options: ollama (default), api, claude-code
#PORCHBENCH_EVAL_BACKEND=claude-code

# Judge model override. Each backend has a sensible default:
#   ollama      -> gemma4:e4b
#   api         -> claude-sonnet-4-6
#   claude-code -> sonnet
#PORCHBENCH_EVAL_MODEL=sonnet

# --- Ollama ---
# Ollama server URL (default: http://localhost:11434)
#OLLAMA_HOST=http://localhost:11434

# KV cache quantization (passed through to Ollama)
#OLLAMA_KV_CACHE_TYPE=q8_0

# --- Inference backend for 'porchbench run' ---
# Which backend porchbench run uses to generate responses under test.
# Options: ollama (default), openai-compat
#PORCHBENCH_BACKEND=openai-compat

# OpenAI-compatible server URL (used when PORCHBENCH_BACKEND=openai-compat)
#PORCHBENCH_BASE_URL=http://localhost:8000/v1

# API key for OpenAI-compatible server
#PORCHBENCH_API_KEY=sk-...

# --- Anthropic API (for 'api' eval backend) ---
#ANTHROPIC_API_KEY=sk-ant-...

# --- Statistics ---
# RNG seed for bootstrap confidence intervals in `porchbench compare`.
# Fixed at 42 by default so runs are byte-identical across invocations.
# Override to probe sensitivity (e.g. re-run with a few seeds and check that
# the CI bounds and effect size don't swing meaningfully).
#PORCHBENCH_SEED=42
